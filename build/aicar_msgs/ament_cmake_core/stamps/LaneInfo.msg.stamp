std_msgs/Header header

# Left lane info
bool   left_detect
float32 left_x        # x position at bottom of BEV [pixels]
float32 left_angle    # line angle [degrees], 90 = vertical

# Right lane info
bool   right_detect
float32 right_x
float32 right_angle

# Quality (optional debug)
int32   left_pixel_count
int32   right_pixel_count
